{
  "manifest_version": 3,
  "name": "Wordo - Word Helper",
  "version": "2.0",
  "description": "Define, translate, and save vocabulary words while browsing",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "clipboardRead",
    "clipboardWrite",
    "tabs"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*",
    "https://api.mymemory.translated.net/*",
    "https://en.wiktionary.org/*",
    "https://docs.google.com/*",
    "https://drive.google.com/*",
    "https://*.googleusercontent.com/*",
    "http://*/*.pdf",
    "https://*/*.pdf",
    "file:///*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Wordo - Word Helper"
  },
  "background": {
    "service_worker": "src/js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/js/functions.js",
        "src/js/handler.js",
        "src/js/floatingIcon.js",
        "src/js/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
